# Normalize line endings; keep Rust sources as UTF-8 text.
* text=auto eol=lf

*.rs text eol=lf
*.wgsl text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.sh text eol=lf
*.py text eol=lf

*.bat text eol=crlf
*.ps1 text eol=crlf

*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.tif binary
*.tiff binary
*.woff binary
*.woff2 binary
