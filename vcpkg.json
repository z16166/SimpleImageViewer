{
  "name": "simple-image-viewer",
  "version-string": "1.5.1",
  "builtin-baseline": "ec3ad1c0b013c51116b7eed2ae25bcfc38e639e9",
  "dependencies": [
    {
      "name": "tiff",
      "features": [
        "jpeg",
        "zip",
        "lzma",
        "webp",
        "zstd",
        "lerc",
        "libdeflate"
      ]
    },
    "libjpeg-turbo",
    {
      "name": "libraw",
      "features": [
        "dng-lossy",
        "x3f"
      ]
    },
    "openexr",
    {
      "name": "libavif",
      "features": [
        "dav1d"
      ]
    },
    "dav1d",
    {
      "name": "libheif",
      "features": [
        "iso23001-17",
        "jpeg",
        "openjpeg",
        "dav1d",
        "h264-decoder",
        "experimental-mini"
      ]
    },
    "libde265",
    "libjxl",
    "zlib"
  ]
}
